{
  "description": "Brain OS plugin hooks for vault task management and skill protection",
  "hooks": {
    "SessionStart": [
      {
        "hooks": [
          {
            "type": "command",
            "command": "H=$(ls -d ~/.claude/plugins/cache/brain-os-marketplace/brain-os/*/hooks 2>/dev/null | grep -E '/[0-9]+\\.[0-9]+\\.[0-9]+/hooks$' | sort -Vr | head -1) && bash \"$H/session-start-tasks.sh\""
          }
        ]
      }
    ],
    "PostToolUse": [
      {
        "matcher": "Edit|Write",
        "hooks": [
          {
            "type": "command",
            "command": "H=$(ls -d ~/.claude/plugins/cache/brain-os-marketplace/brain-os/*/hooks 2>/dev/null | grep -E '/[0-9]+\\.[0-9]+\\.[0-9]+/hooks$' | sort -Vr | head -1) && bash \"$H/smart-diff-check.sh\""
          }
        ]
      },
      {
        "matcher": "Bash",
        "hooks": [
          {
            "type": "command",
            "command": "H=$(ls -d ~/.claude/plugins/cache/brain-os-marketplace/brain-os/*/hooks 2>/dev/null | grep -E '/[0-9]+\\.[0-9]+\\.[0-9]+/hooks$' | sort -Vr | head -1) && bash \"$H/touch-status-dirty.sh\""
          }
        ]
      },
      {
        "hooks": [
          {
            "type": "command",
            "command": "H=$(ls -d ~/.claude/plugins/cache/brain-os-marketplace/brain-os/*/hooks 2>/dev/null | grep -E '/[0-9]+\\.[0-9]+\\.[0-9]+/hooks$' | sort -Vr | head -1) && bash \"$H/trace-capture.sh\""
          }
        ]
      }
    ],
    "SessionEnd": [
      {
        "hooks": [
          {
            "type": "command",
            "command": "H=$(ls -d ~/.claude/plugins/cache/brain-os-marketplace/brain-os/*/hooks 2>/dev/null | grep -E '/[0-9]+\\.[0-9]+\\.[0-9]+/hooks$' | sort -Vr | head -1) && bash \"$H/session-end.sh\""
          }
        ]
      }
    ]
  }
}
